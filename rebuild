#!/usr/bin/env bash
set -euo pipefail

echo "Stopping containers and removing Docker volumes..."

docker compose down -v

read -r -p "Remove local database files in database/data? [y/N] " ans

if [[ "$ans" =~ ^[Yy]$ ]]; then
    echo
    echo "Removing local database files..."
    rm -rf database/data
fi

echo
echo "Rebuilding images without cache..."

docker compose build --no-cache

read -r -p "Start the stack now? [y/N] " ans

if [[ "$ans" =~ ^[Yy]$ ]]; then
    docker compose up
fi
